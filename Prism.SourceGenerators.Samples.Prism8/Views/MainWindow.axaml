<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        x:Class="Prism.SourceGenerators.Samples.Prism8.Views.MainWindow"
        Title="Prism 8.1.97 - Prism.DryIoc.Avalonia Sample"
        Height="560"
        Width="960">
  <Grid ColumnDefinitions="220,*">
    <Border Grid.Column="0" Background="#1F2937" Padding="12">
      <StackPanel Spacing="12">
        <TextBlock Text="Prism 8.1.97 Navigation" FontSize="16" FontWeight="Bold" Foreground="White" />
        <ListBox ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedNavigationItem}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Title}" Margin="4" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock Text="{Binding StatusMessage}"
                   FontSize="11"
                   Foreground="#9CA3AF"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Grid Grid.Column="1" RowDefinitions="Auto,*">
      <StackPanel Margin="20,16,20,8" Spacing="4">
        <TextBlock Text="{Binding CurrentSectionTitle}" FontSize="22" FontWeight="Bold" Foreground="DarkOrange" />
        <TextBlock Text="{Binding CurrentSectionDescription}" FontSize="13" Foreground="Gray" />
      </StackPanel>
      <ContentControl Grid.Row="1"
                      Margin="12,0,12,12"
                      prism:RegionManager.RegionName="ContentRegion" />
    </Grid>
  </Grid>
</Window>

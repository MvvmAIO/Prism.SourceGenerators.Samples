<Window x:Class="Prism.SourceGenerators.Samples.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Height="320"
        Width="480"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="24">
        <TextBlock Text="{Binding Headline}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />
        <TextBlock Text="{Binding Body}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Counter:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="{Binding Counter}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,16,0" />
            <Button Content="Increment" Command="{Binding IncrementCommand}" Padding="12,4" />
        </StackPanel>
        <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" />
    </StackPanel>
</Window>
